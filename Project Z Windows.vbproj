<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
	<TargetFramework>net8.0-windows</TargetFramework>
	<RootNamespace>ProjectZ</RootNamespace>
	<AssemblyName>ProjectZ</AssemblyName>
	<OptionStrict>On</OptionStrict>
	<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
	<UseWindowsForms>true</UseWindowsForms>
	<EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
	<ImplicitUsings>enable</ImplicitUsings>
	<OutputType>Library</OutputType>
	<UseApplicationFramework>True</UseApplicationFramework>
	<SingleInstance>True</SingleInstance>
	<EnableVisualStyles>True</EnableVisualStyles>
	<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
	<Version>2.0.0.0</Version>
	<Title>Project Z</Title>
	<Description>An XNA UI Framework that runs on modern .NET 8.0</Description>
	<PackageReadmeFile>README.md</PackageReadmeFile>
	<PackageIcon>256x256 UI framework(1).png</PackageIcon>
	<PackageProjectUrl>https://github.com/JackOfFates/Project-Z</PackageProjectUrl>
	<PackageLicenseFile>License.txt</PackageLicenseFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Project Z Application\**" />
    <Compile Remove="Project Z Audio\**" />
    <Compile Remove="Project Z Test\**" />
    <Compile Remove="Project Z Tower Defense\**" />
    <Compile Remove="Project Z Video FX\**" />
    <Compile Remove="Project Z.sln.ide\**" />
    <Compile Remove="ProjectTemplate\**" />
    <None Remove="Project Z Application\**" />
    <None Remove="Project Z Audio\**" />
    <None Remove="Project Z Test\**" />
    <None Remove="Project Z Tower Defense\**" />
    <None Remove="Project Z Video FX\**" />
    <None Remove="Project Z.sln.ide\**" />
    <None Remove="ProjectTemplate\**" />
  </ItemGroup>

  <!-- MonoGame DesktopGL (OpenGL) -->
  <ItemGroup>
    <PackageReference Include="nkast.Kni.Platform.SDL2.GL" Version="4.2.9001.1" />
    <PackageReference Include="nkast.Xna.Framework.Graphics" Version="4.2.9001" />
    <PackageReference Include="SocketJack" Version="1.2.3" />
    <PackageReference Include="Speckle.Triangle" Version="1.0.0" />
  </ItemGroup>

  <!-- Project references retained as project references -->

  <!-- Keep resources -->
  <ItemGroup>
    <None Include="..\..\..\..\Downloads\256x256 UI framework(1).png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Include="..\SocketJack\SocketJack\License.txt">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Include=".github\copilot-instructions.md" />
    <None Include=".github\upgrades\scenarios\new-dotnet-version_64215c\plan.md" />
    <EmbeddedResource Include="Properties\Resources.resx">
      <Generator>VbMyResourcesResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.vb</LastGenOutput>
      <CustomToolNamespace>My.Resources</CustomToolNamespace>
    </EmbeddedResource>
    <Compile Update="Properties\Resources.Designer.vb">
      <AutoGen>True</AutoGen>
      <DesignTime>True</DesignTime>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
    <EmbeddedResource Include="Resources\FXAA.mgfx">
      <LogicalName>ProjectZ.Resources.FXAA.mgfx</LogicalName>
    </EmbeddedResource>
  </ItemGroup>
  <ItemGroup>
    <Folder Include="Shared\Drawing\Designer\DesignTime\" />
  </ItemGroup>
  <ItemGroup>
    <None Update="README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

  <!-- Include all VB code files by default (SDK-style) -->

</Project>
