#Region "Tower Menu"

    Private Sub BringTowerMenuToFront()
        ' Remove and re-add menu elements to bring them to front
        RemoveElement(TowerMenuBackground)
        RemoveElement(TowerMenuTitle)
        RemoveElement(UpgradeButton)
        RemoveElement(SellButton)
        RemoveElement(TargetFirstButton)
        RemoveElement(TargetLastButton)
        RemoveElement(TargetClosestButton)
        RemoveElement(TargetStrongestButton)
        RemoveElement(TargetWeakestButton)
        RemoveElement(CloseMenuButton)

        AddElement(TowerMenuBackground)
        AddElement(TowerMenuTitle)
        AddElement(UpgradeButton)
        AddElement(SellButton)
        AddElement(TargetFirstButton)
        AddElement(TargetLastButton)
        AddElement(TargetClosestButton)
        AddElement(TargetStrongestButton)
        AddElement(TargetWeakestButton)
        AddElement(CloseMenuButton)
    End Sub

    Private Sub ShowTowerMenu(tower As Tower)
        SelectedTower = tower
        TowerMenuVisible = True

        ' Bring menu elements to front
        BringTowerMenuToFront()

        ' Position menu near the tower
        Dim menuWidth As Single = 160.0F
        Dim menuHeight As Single = 200.0F
        Dim menuX As Single = tower.Position.X + 30.0F
        Dim menuY As Single = tower.Position.Y - menuHeight / 2.0F

        ' Keep menu on screen
        If menuX + menuWidth > sender.Window.ClientBounds.Width Then
            menuX = tower.Position.X - menuWidth - 30.0F
        End If
        If menuY < 0 Then menuY = 10.0F
        If menuY + menuHeight > sender.Window.ClientBounds.Height Then
            menuY = sender.Window.ClientBounds.Height - menuHeight - 10.0F
        End If

        TowerMenuBackground.Position = New Vector2(menuX, menuY)
        TowerMenuBackground.Size = New Vector2(menuWidth, menuHeight)

        ' Position menu elements
        Dim padding As Single = 10.0F
        Dim yOffset As Single = menuY + padding

        CloseMenuButton.Position = New Vector2(menuX + menuWidth - 30.0F, yOffset)
        TowerMenuTitle.Position = New Vector2(menuX + padding, yOffset + 2.0F)
        yOffset += 30.0F

        ' Upgrade button
        UpgradeButton.Position = New Vector2(menuX + padding, yOffset)
        If tower.CanUpgrade() Then
            UpgradeButton.Text = $"Upgrade (${tower.UpgradeCost})"
            UpgradeButton.isEnabled = Currency >= tower.UpgradeCost
        Else
            UpgradeButton.Text = "Max Level"
            UpgradeButton.isEnabled = False
        End If
        yOffset += 34.0F

        ' Sell button
        SellButton.Position = New Vector2(menuX + padding, yOffset)
        SellButton.Text = $"Sell (${tower.GetSellValue()})"
        yOffset += 40.0F

        ' Targeting label and buttons
        Dim targetY As Single = yOffset
        Dim btnWidth As Single = 65.0F
        Dim btnSpacing As Single = 2.0F

        TargetFirstButton.Position = New Vector2(menuX + padding, targetY)
        TargetLastButton.Position = New Vector2(menuX + padding + btnWidth + btnSpacing, targetY)
        targetY += 28.0F

        TargetClosestButton.Position = New Vector2(menuX + padding, targetY)
        TargetStrongestButton.Position = New Vector2(menuX + padding + btnWidth + btnSpacing, targetY)
        targetY += 28.0F

        TargetWeakestButton.Position = New Vector2(menuX + padding, targetY)

        UpdateTargetingButtonColors()
        TowerMenuTitle.Text = $"{tower.GetType().Name.Replace("Tower", "")} Lv.{tower.Level}"

        ' Show range indicator around the selected tower
        ShowRangeIndicator(tower.Position, tower.Range)
    End Sub

    Private Sub HideTowerMenu()
        TowerMenuVisible = False
        SelectedTower = Nothing

        ' Hide range indicator
        HideRangeIndicator()

        ' Move menu elements off-screen
        Dim offScreen As New Vector2(-1000, -1000)
        TowerMenuBackground.Position = offScreen
        TowerMenuTitle.Position = offScreen
        UpgradeButton.Position = offScreen
        SellButton.Position = offScreen
        TargetFirstButton.Position = offScreen
        TargetLastButton.Position = offScreen
        TargetClosestButton.Position = offScreen
        TargetStrongestButton.Position = offScreen
        TargetWeakestButton.Position = offScreen
        CloseMenuButton.Position = offScreen
    End Sub

    Private Function IsOverTowerMenu(position As Vector2) As Boolean
        If Not TowerMenuVisible Then Return False
        Dim rect As New Rectangle(
            CInt(TowerMenuBackground.Position.X),
            CInt(TowerMenuBackground.Position.Y),
            CInt(TowerMenuBackground.Size.X),
            CInt(TowerMenuBackground.Size.Y))
        Return rect.Contains(CInt(position.X), CInt(position.Y))
    End Function

    Private Sub UpdateTargetingButtonColors()
        If SelectedTower Is Nothing Then Return

        Dim defaultColor As New Color(60, 60, 60)
        Dim selectedColor As New Color(80, 140, 80)

        TargetFirstButton.BackgroundColor = If(SelectedTower.Targeting = TargetingMode.First, selectedColor, defaultColor)
        TargetLastButton.BackgroundColor = If(SelectedTower.Targeting = TargetingMode.Last, selectedColor, defaultColor)
        TargetClosestButton.BackgroundColor = If(SelectedTower.Targeting = TargetingMode.Closest, selectedColor, defaultColor)
        TargetStrongestButton.BackgroundColor = If(SelectedTower.Targeting = TargetingMode.Strongest, selectedColor, defaultColor)
        TargetWeakestButton.BackgroundColor = If(SelectedTower.Targeting = TargetingMode.Weakest, selectedColor, defaultColor)
    End Sub

    Private Sub HandleUpgradeClicked(p As Point)
        If SelectedTower Is Nothing OrElse Not SelectedTower.CanUpgrade() Then Return
        If Currency < SelectedTower.UpgradeCost Then Return
        Dim cost As Integer = 0
        If SelectedTower.Upgrade(cost) Then
            Currency -= cost
            ShowTowerMenu(SelectedTower) ' Refresh menu
        End If
    End Sub

    Private Sub HandleSellClicked(p As Point)
        If SelectedTower Is Nothing Then Return
        Dim sellValue As Integer = SelectedTower.GetSellValue()
        Currency += sellValue
        RemoveTower(SelectedTower)
        HideTowerMenu()
    End Sub

    Private Sub HandleCloseMenuClicked(p As Point)
        HideTowerMenu()
    End Sub

    Private Sub HandleTargetFirstClicked(p As Point)
        If SelectedTower IsNot Nothing Then
            SelectedTower.Targeting = TargetingMode.First
            UpdateTargetingButtonColors()
        End If
    End Sub

    Private Sub HandleTargetLastClicked(p As Point)
        If SelectedTower IsNot Nothing Then
            SelectedTower.Targeting = TargetingMode.Last
            UpdateTargetingButtonColors()
        End If
    End Sub

    Private Sub HandleTargetClosestClicked(p As Point)
        If SelectedTower IsNot Nothing Then
            SelectedTower.Targeting = TargetingMode.Closest
            UpdateTargetingButtonColors()
        End If
    End Sub

    Private Sub HandleTargetStrongestClicked(p As Point)
        If SelectedTower IsNot Nothing Then
            SelectedTower.Targeting = TargetingMode.Strongest
            UpdateTargetingButtonColors()
        End If
    End Sub

    Private Sub HandleTargetWeakestClicked(p As Point)
