    Private Sub HandleTowerDrag(towerType As TowerType, currentPoint As Point)
        If Not GameRunning Then
            HideRangeIndicator()
            Return
        End If
        Dim dragPosition As New Vector2(currentPoint.X, currentPoint.Y)
        If IsInPlayField(dragPosition) Then
            Dim range As Single = GetTowerRange(towerType)
            Dim isValidPlacement As Boolean = Not IsOnPath(dragPosition)
            ' Show green if valid, red if invalid
            RangeIndicator.FillColor = If(isValidPlacement, New Color(100, 200, 100, 60), New Color(200, 100, 100, 60))
            ShowRangeIndicator(dragPosition, range)
            DraggingTowerType = towerType
        Else
            HideRangeIndicator()
        End If
    End Sub

    Private Sub HandleTowerDrop(towerType As TowerType, p As Point)
        If Not GameRunning Then Return
        Dim dropPosition As New Vector2(p.X, p.Y)
        If Not IsInPlayField(dropPosition) Then Return
        If IsOnPath(dropPosition) Then Return
        If IsServer Then
            PlaceTowerInternal(dropPosition, towerType, False)
        ElseIf Client IsNot Nothing Then
            Client.Send(New PlaceTowerMessage With {.Position = dropPosition, .TowerType = towerType})
        End If
    End Sub

    Private Sub HandleBombDrop(p As Point)
        If Not GameRunning Then Return
        If Not IsServer Then Return
        Dim dropPosition As New Vector2(p.X, p.Y)
        If Not IsInPlayField(dropPosition) Then Return
        If Not IsOnPath(dropPosition) Then Return
        If Currency < BOMB_COST Then Return
        Currency -= BOMB_COST
        PlaceBomb(dropPosition)
    End Sub

    Private Sub ResetTowerButtons()
        SpiralTowerButton.Position = SpiralTowerHome
        PointTowerButton.Position = PointTowerHome
        BurstTowerButton.Position = BurstTowerHome
        RapidTowerButton.Position = RapidTowerHome
        SniperTowerButton.Position = SniperTowerHome
        BombButton.Position = BombButtonHome
    End Sub

    Private Function FindTowerAt(position As Vector2) As Tower
        For Each tower As Tower In Towers
            Dim radius As Single = tower.Visual.Size.X / 2.0F
            Dim distance As Single = Vector2.DistanceSquared(tower.Position, position)
            If distance <= radius * radius Then
                Return tower
            End If
        Next
        Return Nothing
    End Function

