    Private Sub RemoveTower(tower As Tower)
        If tower Is Nothing Then Return
        Towers.Remove(tower)
        TowerLookup.Remove(tower.Id)
        RemoveElement(tower.Visual)
    End Sub

#End Region

#Region "Range Indicator"

    Private Sub ShowRangeIndicator(position As Vector2, range As Single)
        RangeIndicator.isVisible = True
        RangeIndicator.Size = New Vector2(range * 2.0F)
        RangeIndicator.Position = position - New Vector2(range)
        RangeIndicator.BringToFront()
    End Sub

    Private Sub HideRangeIndicator()
        RangeIndicator.isVisible = False
        RangeIndicator.Position = New Vector2(-1000, -1000)
    End Sub

    Private Function GetTowerRange(towerType As TowerType) As Single
        Select Case towerType
            Case TowerType.Spiral
                Return 200.0F
            Case TowerType.Burst
                Return 160.0F
            Case TowerType.Rapid
                Return 150.0F
            Case TowerType.Sniper
                Return 260.0F
            Case Else ' Point
                Return 180.0F
        End Select
    End Function

#End Region

#Region "Tooltip"

    Private Sub HandleMouseMove(currentPoint As Point, lastPoint As Point)
        LastMousePosition = currentPoint
    End Sub

    Private Sub UpdateTooltip()
        ' Hide tooltip when tower menu is visible
        If TowerMenuVisible Then
            HideTooltip()
            Return
        End If

        Dim mousePos As New Vector2(LastMousePosition.X, LastMousePosition.Y)
        Dim tooltipContent As String = Nothing

        ' Check tower buttons first
        If IsOverButton(SpiralTowerButton, mousePos) Then
            tooltipContent = GetTowerButtonTooltip(TowerType.Spiral)
        ElseIf IsOverButton(PointTowerButton, mousePos) Then
            tooltipContent = GetTowerButtonTooltip(TowerType.Point)
        ElseIf IsOverButton(BurstTowerButton, mousePos) Then
            tooltipContent = GetTowerButtonTooltip(TowerType.Burst)
        ElseIf IsOverButton(RapidTowerButton, mousePos) Then
            tooltipContent = GetTowerButtonTooltip(TowerType.Rapid)
        ElseIf IsOverButton(SniperTowerButton, mousePos) Then
            tooltipContent = GetTowerButtonTooltip(TowerType.Sniper)
        ElseIf IsOverButton(BombButton, mousePos) Then
            tooltipContent = "Bomb" & Environment.NewLine &
                            "Drag onto the path to place." & Environment.NewLine &
                            "Explodes after a timer, damaging" & Environment.NewLine &
                            "all enemies in the blast radius." & Environment.NewLine &
                            "Cost: $5"
        ElseIf IsOverButton(StartButton, mousePos) Then
            tooltipContent = "Click to start the game." & Environment.NewLine & "Enemies will spawn and follow the path."
        ElseIf IsOverButton(StopButton, mousePos) Then
            tooltipContent = "Click to stop the current game." & Environment.NewLine & "All progress will be reset."
        ElseIf IsOverButton(HostButton, mousePos) Then
            tooltipContent = "Host a multiplayer game." & Environment.NewLine & "Other players can join as clients."
        ElseIf IsOverButton(ClientButton, mousePos) Then
            tooltipContent = "Join a hosted game as a client." & Environment.NewLine & "Connect to localhost:4040."
        ElseIf GameRunning AndAlso IsInPlayField(mousePos) Then
            ' Check placed towers
            Dim tower As Tower = FindTowerAt(mousePos)
            If tower IsNot Nothing Then
                tooltipContent = GetPlacedTowerTooltip(tower)
            Else
                ' Check enemies
                Dim enemy As Enemy = FindEnemyAt(mousePos)
                If enemy IsNot Nothing Then
                    tooltipContent = GetEnemyTooltip(enemy)
                End If
            End If
        End If

        If tooltipContent IsNot Nothing Then
            ShowTooltip(tooltipContent, LastMousePosition)
        Else
            HideTooltip()
        End If
    End Sub

    Private Function IsOverButton(button As Button, mousePos As Vector2) As Boolean
        Dim rect As New Rectangle(CInt(button.Position.X), CInt(button.Position.Y), CInt(button.Size.X), CInt(button.Size.Y))
        Return rect.Contains(CInt(mousePos.X), CInt(mousePos.Y))
    End Function

    Private Function GetTowerButtonTooltip(towerType As TowerType) As String
        Dim name As String = ""
        Dim damage As Single = 0
        Dim range As Single = 0
        Dim fireRate As Single = 0
        Dim cost As Integer = 0
        Dim description As String = ""

        Select Case towerType
            Case TowerType.Spiral
                name = "Spiral Tower"
                damage = 6.0F
                range = 200.0F
                fireRate = 1.6F
                cost = 65
                description = "Fires projectiles in a spiral pattern."
            Case TowerType.Burst
                name = "Burst Tower"
                damage = 5.0F
                range = 160.0F
                fireRate = 0.9F
                cost = 75
                description = "Fires 3 projectiles in a spread."
            Case TowerType.Rapid
                name = "Rapid Tower"
                damage = 3.5F
                range = 150.0F
                fireRate = 2.4F
                cost = 40
                description = "Fast firing, low damage."
            Case TowerType.Sniper
                name = "Sniper Tower"
                damage = 14.0F
                range = 260.0F
                fireRate = 0.6F
                cost = 90
                description = "Long range, high damage, slow."
            Case Else ' Point
                name = "Point Tower"
                damage = 8.0F
                range = 180.0F
                fireRate = 1.2F
                cost = 50
                description = "Balanced tower. Good all-around."
        End Select

        Return $"{name}" & Environment.NewLine &
               $"{description}" & Environment.NewLine &
               $"Damage: {damage:F1}" & Environment.NewLine &
               $"Range: {range:F0}" & Environment.NewLine &
               $"Fire Rate: {fireRate:F1}/s" & Environment.NewLine &
               $"Cost: ${cost}"
    End Function

    Private Function GetPlacedTowerTooltip(tower As Tower) As String
        Dim typeName As String = tower.GetType().Name.Replace("Tower", " Tower")

        Return $"{typeName} (Lv.{tower.Level})" & Environment.NewLine &
               $"Targeting: {tower.Targeting.ToString()}" & Environment.NewLine &
               $"Damage: {tower.Damage:F1}" & Environment.NewLine &
               $"Range: {tower.Range:F0}" & Environment.NewLine &
               $"Fire Rate: {tower.FireRate:F1}/s" & Environment.NewLine &
               $"Sell Value: ${tower.GetSellValue()}" & Environment.NewLine &
               "Click to open tower menu"
    End Function

    Private Function GetEnemyTooltip(enemy As Enemy) As String
        Dim healthPercent As Single = (enemy.Health / enemy.MaxHealth) * 100.0F
        Dim typeName As String = "Normal"
        If enemy.TypeBlend > 0.7F Then
            typeName = "Tank"
        ElseIf enemy.TypeBlend > 0.4F Then
            typeName = "Tough"
        ElseIf enemy.TypeBlend < 0.2F Then
            typeName = "Fast"
        End If

        Return $"Enemy ({typeName})" & Environment.NewLine &
               $"Health: {enemy.Health:F0}/{enemy.MaxHealth:F0} ({healthPercent:F0}%)" & Environment.NewLine &
               $"Speed: {enemy.Speed:F0}"
    End Function

    Private Function FindEnemyAt(position As Vector2) As Enemy
        For Each enemy As Enemy In Enemies
            Dim distance As Single = Vector2.DistanceSquared(enemy.Position, position)
            If distance <= enemy.Radius * enemy.Radius * 2.0F Then ' Slightly larger hit area for easier hover
                Return enemy
            End If
        Next
        Return Nothing
    End Function

    Private Sub ShowTooltip(content As String, mousePos As Point)
        TooltipText.Text = content
        TooltipVisible = True

        ' Bring tooltip to front so it appears above other elements
        TooltipBackground.BringToFront()
        TooltipText.BringToFront()

        ' Calculate tooltip size based on text
        Dim padding As Single = 8.0F
        Dim textSize As Vector2 = TooltipText.Size
        If textSize.X < 10 Then textSize = New Vector2(200, 80) ' Default size if text not measured yet

        ' Position tooltip near mouse, but keep on screen
        Dim tooltipX As Single = mousePos.X + 15.0F
        Dim tooltipY As Single = mousePos.Y + 15.0F

        ' Clamp to screen bounds
        If tooltipX + textSize.X + padding * 2 > sender.Window.ClientBounds.Width Then
            tooltipX = mousePos.X - textSize.X - padding * 2 - 10.0F
        End If
        If tooltipY + textSize.Y + padding * 2 > sender.Window.ClientBounds.Height Then
            tooltipY = mousePos.Y - textSize.Y - padding * 2 - 10.0F
        End If

        TooltipBackground.Position = New Vector2(tooltipX, tooltipY)
        TooltipBackground.Size = New Vector2(textSize.X + padding * 2, textSize.Y + padding * 2)
        TooltipText.Position = New Vector2(tooltipX + padding, tooltipY + padding)

        TooltipBackground.BackgroundColor = New Color(30, 30, 30, 230)
    End Sub

    Private Sub HideTooltip()
        If TooltipVisible Then
            TooltipVisible = False
            TooltipText.Text = ""
            TooltipBackground.Position = New Vector2(-1000, -1000) ' Move off-screen
        End If
    End Sub

#End Region

#Region "IDisposable Support"

    Protected Overrides Sub Dispose(disposing As Boolean)
        If disposing Then
            ' Stop the game first
            If GameRunning Then
                StopGame()
            End If

            ' Dispose networking resources - this stops the background threads
            Try
                If Server IsNot Nothing Then
                    Server.Dispose()
                    Server = Nothing
                End If
            Catch
            End Try

            Try
                If Client IsNot Nothing Then
                    Client.Dispose()
                    Client = Nothing
                End If
            Catch
            End Try

            ' Clear pending queues
            Dim dummy As MapDataMessage = Nothing
            While PendingMap.TryDequeue(dummy)
            End While

            Dim dummy2 As GameStateMessage = Nothing
            While PendingStates.TryDequeue(dummy2)
            End While
        End If

        MyBase.Dispose(disposing)
    End Sub

#End Region

End Class
