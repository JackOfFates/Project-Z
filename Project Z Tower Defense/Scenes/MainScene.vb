#Region "Input Handling"

    Private Sub HandleMouseLeftClick(p As Point)
        Dim clickPosition As New Vector2(p.X, p.Y)

        ' If menu is visible and click is outside menu, close it
        If TowerMenuVisible Then
            If Not IsOverTowerMenu(clickPosition) Then
                HideTowerMenu()
            End If
            Return
        End If

        If Not GameRunning Then Return
        If Not IsInPlayField(clickPosition) Then Return

        ' Check if clicked on a tower
        Dim tower As Tower = FindTowerAt(clickPosition)
        If tower IsNot Nothing AndAlso IsServer Then
            ShowTowerMenu(tower)
        End If
    End Sub

    Private Sub HandleMouseRightClick(p As Point)
        Dim clickPosition As New Vector2(p.X, p.Y)
        If TowerMenuVisible Then
            HideTowerMenu()
            Return
        End If
    End Sub

    Private Sub HandleKeyPress(key As Keys, keyboardState As KeyboardState)
        If key = Keys.Escape AndAlso TowerMenuVisible Then
            HideTowerMenu()
        End If
    End Sub

    Private Sub PlaceTowerInternal(position As Vector2, towerType As TowerType, ignoreCurrency As Boolean)
        Dim tower As Tower = CreateTower(towerType, position)
        If tower Is Nothing Then Return
        If Not IsInPlayField(position) Then Return
        If IsOnPath(position) Then Return
        If Not ignoreCurrency AndAlso Currency < tower.Cost Then Return
        If Not ignoreCurrency Then
            Currency -= tower.Cost
        End If
        Towers.Add(tower)
        TowerLookup(tower.Id) = tower
        AddElement(tower.Visual)
        SpawnTowerPlacementEffect(position)
    End Sub

    Private Function CreateTower(towerType As TowerType, position As Vector2) As Tower
        Select Case towerType
            Case TowerType.Spiral
                Return New SpiralTower(Me, position)
            Case TowerType.Burst
                Return New BurstTower(Me, position)
            Case TowerType.Rapid
                Return New RapidTower(Me, position)
            Case TowerType.Sniper
                Return New SniperTower(Me, position)
            Case Else
                Return New PointTower(Me, position)
        End Select
    End Function

    Private Sub SpawnTowerPlacementEffect(position As Vector2)
        Dim ripple As New RippleEffect(Me, position, 50.0F, 0.4F)
        For Each visual In ripple.Visuals
            AddElement(visual)
        Next
        RippleEffects.Add(ripple)
    End Sub

    Private Sub UpdateRippleEffects(deltaSeconds As Single)
        For i As Integer = RippleEffects.Count - 1 To 0 Step -1
            Dim ripple = RippleEffects(i)
            If ripple.Update(deltaSeconds) Then
                ' Effect complete, remove visuals
                For Each visual In ripple.Visuals
                    RemoveElement(visual)
                Next
                RippleEffects.RemoveAt(i)
            End If
        Next
    End Sub

#End Region

