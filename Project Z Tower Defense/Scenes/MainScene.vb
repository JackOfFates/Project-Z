    Private Function GetTowerCost(towerType As TowerType) As Integer
        Select Case towerType
            Case TowerType.Spiral
                Return 65
            Case TowerType.Burst
                Return 75
            Case TowerType.Rapid
                Return 40
            Case TowerType.Sniper
                Return 90
            Case Else
                Return 50
        End Select
    End Function

    Private Sub BuildPathSegments()
        Dim thickness As Single = 28.0F
        Dim startColor As New Color(20, 60, 20)
        Dim endColor As New Color(120, 200, 120)
        For i As Integer = 0 To PathPoints.Count - 2
            Dim start As Vector2 = PathPoints(i)
            Dim [end] As Vector2 = PathPoints(i + 1)
            Dim blend As Single = If(PathPoints.Count <= 2, 1.0F, CSng(i) / CSng(PathPoints.Count - 2))
            Dim minX As Single = Math.Min(start.X, [end].X) - thickness / 2.0F
            Dim minY As Single = Math.Min(start.Y, [end].Y) - thickness / 2.0F
            Dim width As Single = Math.Abs(start.X - [end].X) + thickness
            Dim height As Single = Math.Abs(start.Y - [end].Y) + thickness
            Dim segment As New RectangleElement(Me) With {
                .BackgroundColor = Color.Lerp(startColor, endColor, blend),
                .isMovable = False,
                .isMouseBypassEnabled = True
            }
            segment.Position = New Vector2(minX, minY)
            segment.Size = New Vector2(width, height)
            PathSegments.Add(segment)
            AddElement(segment)
        Next
    End Sub

    Private Function IsOnPath(position As Vector2) As Boolean
        For Each segment As RectangleElement In PathSegments
            Dim rect As New Rectangle(CInt(segment.Position.X), CInt(segment.Position.Y), CInt(segment.Size.X), CInt(segment.Size.Y))
            If rect.Contains(CInt(position.X), CInt(position.Y)) Then
                Return True
            End If
        Next
        Return False
    End Function

    Private Function IsInPlayField(position As Vector2) As Boolean
        Dim rect As New Rectangle(CInt(PlayField.Position.X), CInt(PlayField.Position.Y), CInt(PlayField.Size.X), CInt(PlayField.Size.Y))
        Return rect.Contains(CInt(position.X), CInt(position.Y))
    End Function

