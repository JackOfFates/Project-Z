#Region "Main Game Loop"

    Public Overrides Sub Tick(gameTime As GameTime)
        MyBase.Tick(gameTime)
        Dim deltaSeconds As Single = CSng(gameTime.ElapsedGameTime.TotalSeconds)
        UpdateLayoutIfNeeded()
        UpdateRippleEffects(deltaSeconds)
        If GameRunning Then
            ProcessPendingNetwork()
            If IsServer Then
                UpdateServer(deltaSeconds)
            Else
                UpdateClient(deltaSeconds)
            End If
        End If
        UpdateHud()
        UpdateTooltip()
    End Sub

    Private Sub SetupLayout()
        Dim panelWidth As Single = 220.0F
        SidePanel.Position = Vector2.Zero
        SidePanel.Size = New Vector2(panelWidth, sender.Window.ClientBounds.Height)
        PlayField.Position = New Vector2(panelWidth, 0)
        PlayField.Size = New Vector2(sender.Window.ClientBounds.Width - panelWidth, sender.Window.ClientBounds.Height)
        EnemiesText.Position = New Vector2(16, 24)
        LevelText.Position = New Vector2(16, 56)
        CurrencyText.Position = New Vector2(16, 88)
        HealthText.Position = New Vector2(16, 120)
        TowerHintText.Position = New Vector2(16, 160)
        NetworkModeText.Position = New Vector2(16, 200)
        HostButton.Position = New Vector2(16, 230)
        ClientButton.Position = New Vector2(16, 270)
        StartButton.Position = New Vector2(16, 330)
        StopButton.Position = New Vector2(16, 370)
        SpiralTowerButton.Position = New Vector2(16, 430)
        PointTowerButton.Position = New Vector2(16, 470)
        BurstTowerButton.Position = New Vector2(16, 510)
        RapidTowerButton.Position = New Vector2(16, 550)
        SniperTowerButton.Position = New Vector2(16, 590)
        BombButton.Position = New Vector2(16, 640)
        SpiralTowerHome = SpiralTowerButton.Position
        PointTowerHome = PointTowerButton.Position
        BurstTowerHome = BurstTowerButton.Position
        RapidTowerHome = RapidTowerButton.Position
        SniperTowerHome = SniperTowerButton.Position
        BombButtonHome = BombButton.Position
        LastWindowSize = sender.Window.ClientBounds.Size
    End Sub

    Private Sub UpdateLayoutIfNeeded()
        Dim currentSize As Point = sender.Window.ClientBounds.Size
        If currentSize <> LastWindowSize Then
            Dim oldPlayFieldPosition As Vector2 = PlayField.Position
            Dim oldPlayFieldSize As Vector2 = PlayField.Size
            SetupLayout()
            If GameRunning AndAlso IsServer Then
                RescaleGameEntities(oldPlayFieldPosition, oldPlayFieldSize, PlayField.Position, PlayField.Size)
            End If
        End If
    End Sub

#End Region

#Region "Networking"

    Private Sub SetupNetwork()
        If Not ManualNetworkMode Then
            Dim args As String() = Environment.GetCommandLineArgs()
            If args.Any(Function(arg) arg.Equals("--client", StringComparison.OrdinalIgnoreCase)) Then
                IsServer = False
            ElseIf args.Any(Function(arg) arg.Equals("--server", StringComparison.OrdinalIgnoreCase)) Then
                IsServer = True
            End If
        End If

        If IsServer Then
            Server = New TcpServer(Port:=4040)
            Server.RegisterCallback(Of ClientReadyMessage)(AddressOf OnClientReady)
            Server.RegisterCallback(Of PlaceTowerMessage)(AddressOf OnPlaceTowerReceived)
            Server.Listen()
        End If

        Client = New TcpClient("TowerDefenseClient")
        Client.RegisterCallback(Of MapDataMessage)(AddressOf OnMapDataReceived)
        Client.RegisterCallback(Of GameStateMessage)(AddressOf OnGameStateReceived)
        Client.Connect("127.0.0.1", 4040)
        SentReady = False
    End Sub

    Private Sub RescalePath(oldPosition As Vector2, oldSize As Vector2, newPosition As Vector2, newSize As Vector2)
        If oldSize.X <= 0 OrElse oldSize.Y <= 0 Then Return
        If PathPoints.Count = 0 Then Return
        Dim scaleX As Single = newSize.X / oldSize.X
        Dim scaleY As Single = newSize.Y / oldSize.Y
        For i As Integer = 0 To PathPoints.Count - 1
            Dim relative As Vector2 = PathPoints(i) - oldPosition
            PathPoints(i) = newPosition + New Vector2(relative.X * scaleX, relative.Y * scaleY)
        Next
        For i As Integer = 0 To Math.Min(PathNodes.Count, PathPoints.Count) - 1
            PathNodes(i).Position = PathPoints(i) - New Vector2(5.0F)
        Next
        For Each segment As RectangleElement In PathSegments
            RemoveElement(segment)
        Next
        PathSegments.Clear()
        BuildPathSegments()
    End Sub

    ''' <summary>
    ''' Rescales all game entities (path, enemies, towers, bombs, health orbs, projectiles) when the window is resized.
    ''' </summary>
    Private Sub RescaleGameEntities(oldPosition As Vector2, oldSize As Vector2, newPosition As Vector2, newSize As Vector2)
        If oldSize.X <= 0 OrElse oldSize.Y <= 0 Then Return

        Dim scaleX As Single = newSize.X / oldSize.X
        Dim scaleY As Single = newSize.Y / oldSize.Y

        ' Rescale path
        RescalePath(oldPosition, oldSize, newPosition, newSize)

        ' Rescale enemies
        For Each enemy As Enemy In Enemies
            enemy.Position = RescalePosition(enemy.Position, oldPosition, oldSize, newPosition, newSize)
            enemy.UpdateVisual()
        Next

        ' Rescale towers
        For Each tower As Tower In Towers
            tower.Position = RescalePosition(tower.Position, oldPosition, oldSize, newPosition, newSize)
            tower.Range *= Math.Max(scaleX, scaleY) ' Scale range proportionally
            tower.UpdateVisual()
        Next

        ' Rescale bombs
        For Each bomb As Bomb In Bombs
            bomb.Position = RescalePosition(bomb.Position, oldPosition, oldSize, newPosition, newSize)
            bomb.UpdateVisual()
        Next

        ' Rescale health orbs
        For Each orb As HealthOrb In HealthOrbs
            orb.Position = RescalePosition(orb.Position, oldPosition, oldSize, newPosition, newSize)
            orb.UpdateVisual()
        Next

        ' Rescale projectiles
        For Each projectile As Projectile In Projectiles
            projectile.Position = RescalePosition(projectile.Position, oldPosition, oldSize, newPosition, newSize)
            projectile.UpdateVisual()
        Next

        ' Rescale ripple effects
        For Each ripple As RippleEffect In RippleEffects
            ripple.Position = RescalePosition(ripple.Position, oldPosition, oldSize, newPosition, newSize)
        Next
    End Sub

    ''' <summary>
    ''' Helper function to rescale a position from old playfield coordinates to new playfield coordinates.
    ''' </summary>
    Private Function RescalePosition(position As Vector2, oldPosition As Vector2, oldSize As Vector2, newPosition As Vector2, newSize As Vector2) As Vector2
        If oldSize.X <= 0 OrElse oldSize.Y <= 0 Then Return position
        Dim scaleX As Single = newSize.X / oldSize.X
        Dim scaleY As Single = newSize.Y / oldSize.Y
        Dim relative As Vector2 = position - oldPosition
        Return newPosition + New Vector2(relative.X * scaleX, relative.Y * scaleY)
    End Function

    Private Sub ProcessPendingNetwork()
        If IsServer Then
            ' Server doesn't process incoming game state
            Return
        End If

        ' Process all pending map data first (must be done before game state)
        Dim mapData As MapDataMessage = Nothing
        While PendingMap.TryDequeue(mapData)
            ApplyMap(mapData)
            MapReceived = True
        End While

        ' Only process game states after map has been received
        If MapReceived Then
            Dim state As GameStateMessage = Nothing
            While PendingStates.TryDequeue(state)
                ApplyGameState(state)
            End While
        End If

        ' Send ready message to server only after connection is established
        If Client IsNot Nothing AndAlso Client.Connected AndAlso Not SentReady Then
            SentReady = True
            Client.Send(New ClientReadyMessage())
        End If
    End Sub

    Private Sub OnClientReady(args As ReceivedEventArgs(Of ClientReadyMessage))
        If Not IsServer Then Return
        Dim mapMessage As New MapDataMessage With {
            .Path = New List(Of Vector2)(PathPoints),
            .PlayfieldSize = PlayField.Size,
            .SidePanelWidth = SidePanel.Size.X,
            .Level = Level
        }
        args.Connection.Send(mapMessage)
        ' Also send current game state immediately
        SendGameStateToConnection(args.Connection)
    End Sub

    Private Sub OnMapDataReceived(args As ReceivedEventArgs(Of MapDataMessage))
        PendingMap.Enqueue(args.Object)
    End Sub

    Private Sub OnGameStateReceived(args As ReceivedEventArgs(Of GameStateMessage))
        PendingStates.Enqueue(args.Object)
    End Sub

    Private Sub OnPlaceTowerReceived(args As ReceivedEventArgs(Of PlaceTowerMessage))
        If Not IsServer Then Return
        PlaceTowerInternal(args.Object.Position, args.Object.TowerType, True)
    End Sub

#End Region

#Region "Button Click Handlers"

    Private Sub HandleHostClicked(p As Point)
        If GameRunning Then Return
        ManualNetworkMode = True
        IsServer = True
        UpdateNetworkUi()
    End Sub

    Private Sub HandleClientClicked(p As Point)
        If GameRunning Then Return
        ManualNetworkMode = True
        IsServer = False
        UpdateNetworkUi()
    End Sub

    Private Sub HandleStartClicked(p As Point)
        If GameRunning Then Return
        If Not NetworkInitialized Then
            SetupNetwork()
            NetworkInitialized = True
        End If
        GameRunning = True
        GameHealth = MaxGameHealth
        If IsServer Then
            GenerateMap()
            StartLevel()
        End If
        UpdateNetworkUi()
    End Sub

    Private Sub HandleStopClicked(p As Point)
        If Not GameRunning Then Return
        StopGame()
    End Sub

#End Region

#Region "Game Logic"

    Private Sub StopGame(Optional resetHealth As Boolean = True)
        GameRunning = False
        EnemiesToSpawn = 0
        EnemiesRemaining = 0
        EnemySpawnTimer = 0.0F
        MapReceived = False
        SentReady = False
        If resetHealth Then
            GameHealth = MaxGameHealth
        End If
        For Each enemy As Enemy In Enemies.ToList()
            RemoveEnemy(enemy)
        Next
        For Each bomb As Bomb In Bombs.ToList()
            RemoveBomb(bomb)
        Next
        For Each orb As HealthOrb In HealthOrbs.ToList()
            RemoveHealthOrb(orb)
        Next
        For Each projectile As Projectile In Projectiles.ToList()
            RemoveProjectile(projectile)
        Next
        For Each tower As Tower In Towers.ToList()
            Towers.Remove(tower)
            TowerLookup.Remove(tower.Id)
            RemoveElement(tower.Visual)
        Next
        PathPoints.Clear()
        For Each node As CircleElement In PathNodes.ToList()
            RemoveElement(node)
        Next
        PathNodes.Clear()
        For Each segment As RectangleElement In PathSegments.ToList()
            RemoveElement(segment)
        Next
        PathSegments.Clear()
        For Each ripple As RippleEffect In RippleEffects.ToList()
            For Each visual In ripple.Visuals
                RemoveElement(visual)
            Next
        Next
        RippleEffects.Clear()
        UpdateNetworkUi()
    End Sub

    Private Sub UpdateServer(deltaSeconds As Single)
        If PathPoints.Count = 0 Then
            GenerateMap()
        End If

        EnemySpawnTimer -= deltaSeconds
        If EnemiesToSpawn > 0 AndAlso EnemySpawnTimer <= 0 Then
            SpawnEnemy()
            EnemiesToSpawn -= 1
            EnemySpawnTimer = 0.75F
        End If

        For Each enemy As Enemy In Enemies.ToList()
            enemy.Update(PathPoints, deltaSeconds)
            If enemy.ReachedEnd Then
                RemoveEnemy(enemy)
                GameHealth = Math.Max(0, GameHealth - 1)
                If GameHealth = 0 Then
                    StopGame(False)
                    Return
                End If
                Continue For
            End If
        Next

        For Each bomb As Bomb In Bombs.ToList()
            bomb.Update(deltaSeconds)
            If bomb.Countdown <= 0 Then
                ExplodeBomb(bomb)
            End If
        Next

        For Each projectile As Projectile In Projectiles.ToList()
            projectile.Update(deltaSeconds)
            If projectile.Lifetime > 4.0F Then
                RemoveProjectile(projectile)
            End If
        Next

        For Each tower As Tower In Towers
            tower.Update(deltaSeconds, Enemies, Projectiles, Me)
        Next

        ' Register any new projectiles created by towers
        For Each projectile As Projectile In Projectiles
            If Not ProjectileLookup.ContainsKey(projectile.Id) Then
                ProjectileLookup(projectile.Id) = projectile
                AddElement(projectile.Visual)
            End If
        Next

        HandleProjectileCollisions()
        HandleHealthPickups()

        If EnemiesRemaining = 0 AndAlso Enemies.Count = 0 AndAlso EnemiesToSpawn = 0 Then
            Level += 1
            StartLevel()
        End If

        NetworkTickTimer += deltaSeconds
        If NetworkTickTimer >= NetworkTickRate Then
            NetworkTickTimer = 0.0F
            SendGameState()
        End If
    End Sub

    Private Sub UpdateClient(deltaSeconds As Single)
        For Each bomb As Bomb In Bombs
            bomb.Update(deltaSeconds)
        Next
    End Sub

    Private Sub GenerateMap()
        SetupLayout()
        PathPoints.Clear()
        For Each node As CircleElement In PathNodes
            RemoveElement(node)
        Next
        PathNodes.Clear()
        For Each segment As RectangleElement In PathSegments
            RemoveElement(segment)
        Next
        PathSegments.Clear()

        Dim margin As Single = 60.0F
        Dim startX As Single = PlayField.Position.X + margin
        Dim endX As Single = PlayField.Position.X + PlayField.Size.X - margin
        Dim numCorners As Integer = 5
        Dim stepX As Single = (endX - startX) / numCorners
        Dim yRange As Single = PlayField.Size.Y - margin * 2.0F
        Dim currentPos As New Vector2(startX, PlayField.Position.Y + PlayField.Size.Y / 2.0F)
        PathPoints.Add(currentPos)
        For i As Integer = 1 To numCorners
            Dim targetX As Single = startX + stepX * i
            Dim targetY As Single = PlayField.Position.Y + margin + CSng(Randomizer.NextDouble()) * yRange
            ' Move horizontally first
            currentPos = New Vector2(targetX, currentPos.Y)
            PathPoints.Add(currentPos)
            ' Then move vertically
            currentPos = New Vector2(targetX, targetY)
            PathPoints.Add(currentPos)
        Next

        For Each point As Vector2 In PathPoints
            Dim marker As New CircleElement(Me) With {
                .Size = New Vector2(10.0F),
                .FillColor = Color.DimGray
            }
            marker.Position = point - New Vector2(5.0F)
            PathNodes.Add(marker)
            AddElement(marker)
        Next
        BuildPathSegments()
    End Sub

    Private Sub StartLevel()
        EnemiesToSpawn = 6 + (Level - 1) * 4
        EnemiesRemaining = EnemiesToSpawn
        EnemySpawnTimer = 0.5F
        SpawnHealthOrb()
    End Sub

    Private Sub SpawnEnemy()
        If PathPoints.Count = 0 Then Return
        Dim typeBlend As Single = CSng(Randomizer.NextDouble())
        Dim baseSpeed As Single = 70.0F + Level * 3.0F
        Dim baseHealth As Single = 22.0F + Level * 5.0F
        Dim speed As Single = Math.Max(35.0F, baseSpeed * (1.0F - typeBlend * 0.35F))
        Dim maxHealth As Single = baseHealth * (1.0F + typeBlend * 0.6F)
        Dim enemy As New Enemy(Me, PathPoints(0), 14.0F, speed, maxHealth, typeBlend)
        Enemies.Add(enemy)
        EnemyLookup(enemy.Id) = enemy
        AddElement(enemy.Visual)
    End Sub

    Private Sub PlaceBomb(position As Vector2)
        Dim countdown As Single = Math.Max(1.5F, 6.0F - Level * 0.3F)
        Dim bomb As New Bomb(Me, position, 16.0F, countdown, 80.0F)
        Bombs.Add(bomb)
        BombLookup(bomb.Id) = bomb
        AddElement(bomb.Visual)
        AddElement(bomb.TimerText)
    End Sub

    Private Sub SpawnHealthOrb()
        Dim position As Vector2 = GetRandomPointOnPath()
        Dim orb As New HealthOrb(Me, position, 12.0F, 5.0F)
        HealthOrbs.Add(orb)
        HealthLookup(orb.Id) = orb
        AddElement(orb.Visual)
    End Sub

    Private Function GetRandomPointOnPath() As Vector2
        If PathPoints.Count < 2 Then Return GetRandomPointInPlayfield()
        ' Pick a random segment
        Dim segmentIndex As Integer = Randomizer.Next(0, PathPoints.Count - 1)
        Dim startPoint As Vector2 = PathPoints(segmentIndex)
        Dim endPoint As Vector2 = PathPoints(segmentIndex + 1)
        ' Pick a random point along that segment
        Dim t As Single = CSng(Randomizer.NextDouble())
        Return Vector2.Lerp(startPoint, endPoint, t)
    End Function

    Private Function GetRandomPointInPlayfield() As Vector2
        Dim x As Single = PlayField.Position.X + 60.0F + CSng(Randomizer.NextDouble()) * (PlayField.Size.X - 120.0F)
        Dim y As Single = PlayField.Position.Y + 60.0F + CSng(Randomizer.NextDouble()) * (PlayField.Size.Y - 120.0F)
        Return New Vector2(x, y)
    End Function

    Private Sub ExplodeBomb(bomb As Bomb)
        Dim blast As New CircleCollider With {.Position = bomb.Position, .Radius = bomb.ExplosionRadius}
        For Each enemy As Enemy In Enemies.ToList()
            If blast.Intersects(enemy.Collider()) Then
                enemy.Health -= BOMB_DAMAGE
                If enemy.IsDead() Then
                    RemoveEnemy(enemy)
                    Currency += BOMB_KILL_REWARD
                End If
            End If
        Next
        RemoveBomb(bomb)
    End Sub

    Private Sub HandleProjectileCollisions()
        For Each projectile As Projectile In Projectiles.ToList()
            Dim hit As Boolean = False
            For Each enemy As Enemy In Enemies.ToList()
                If projectile.Collider().Intersects(enemy.Collider()) Then
                    enemy.Health -= projectile.Damage
                    hit = True
                    If enemy.IsDead() Then
                        RemoveEnemy(enemy)
                        Currency += ENEMY_KILL_REWARD
                    End If
                    Exit For
                End If
            Next
            If hit Then
                RemoveProjectile(projectile)
            End If
        Next
    End Sub

    Private Sub HandleHealthPickups()
        For Each orb As HealthOrb In HealthOrbs.ToList()
            For Each enemy As Enemy In Enemies.ToList()
                If orb.Collider().Intersects(enemy.Collider()) Then
                    enemy.Health = Math.Min(enemy.MaxHealth, enemy.Health + orb.Amount)
                    RemoveHealthOrb(orb)
                    Exit For
                End If
            Next
        Next
    End Sub

    Private Sub RemoveEnemy(enemy As Enemy)
        If enemy Is Nothing Then Return
        Enemies.Remove(enemy)
        EnemyLookup.Remove(enemy.Id)
        RemoveElement(enemy.Visual)
        EnemiesRemaining = Math.Max(0, EnemiesRemaining - 1)
    End Sub

    Private Sub RemoveBomb(bomb As Bomb)
        Bombs.Remove(bomb)
        BombLookup.Remove(bomb.Id)
        RemoveElement(bomb.Visual)
        RemoveElement(bomb.TimerText)
    End Sub

    Private Sub RemoveHealthOrb(orb As HealthOrb)
        HealthOrbs.Remove(orb)
        HealthLookup.Remove(orb.Id)
        RemoveElement(orb.Visual)
    End Sub

    Private Sub RemoveProjectile(projectile As Projectile)
        Projectiles.Remove(projectile)
        ProjectileLookup.Remove(projectile.Id)
        RemoveElement(projectile.Visual)
    End Sub

    Private Sub SendGameState()
        If Server Is Nothing Then Return
        Dim state As New GameStateMessage With {
            .Enemies = Enemies.Select(Function(enemy) New EnemyState With {
                .Id = enemy.Id,
                .Position = enemy.Position,
                .Radius = enemy.Radius,
                .Health = enemy.Health,
                .MaxHealth = enemy.MaxHealth,
                .TypeBlend = enemy.TypeBlend
            }).ToList(),
            .Bombs = Bombs.Select(Function(bomb) New BombState With {
                .Id = bomb.Id,
                .Position = bomb.Position,
                .Radius = bomb.Radius,
                .Countdown = bomb.Countdown,
                .ExplosionRadius = bomb.ExplosionRadius
            }).ToList(),
            .HealthOrbs = HealthOrbs.Select(Function(orb) New HealthState With {
                .Id = orb.Id,
                .Position = orb.Position,
                .Radius = orb.Radius,
                .Amount = orb.Amount
            }).ToList(),
            .Projectiles = Projectiles.Select(Function(proj) New ProjectileState With {
                .Id = proj.Id,
                .Position = proj.Position,
                .Radius = proj.Radius,
                .Velocity = proj.RigidBody.Velocity
            }).ToList(),
            .Towers = Towers.Select(Function(tower) New TowerState With {
                .Id = tower.Id,
                .Position = tower.Position,
                .TowerType = GetTowerType(tower)
            }).ToList(),
            .Level = Level,
            .Currency = Currency,
            .EnemiesRemaining = EnemiesRemaining,
            .GameHealth = GameHealth,
            .MaxGameHealth = MaxGameHealth
        }
        Server.SendBroadcast(state)
    End Sub

    Private Sub SendGameStateToConnection(connection As SocketJack.Net.TcpConnection)
        If connection Is Nothing Then Return
        Dim state As New GameStateMessage With {
            .Enemies = Enemies.Select(Function(enemy) New EnemyState With {
                .Id = enemy.Id,
                .Position = enemy.Position,
                .Radius = enemy.Radius,
                .Health = enemy.Health,
                .MaxHealth = enemy.MaxHealth,
                .TypeBlend = enemy.TypeBlend
            }).ToList(),
            .Bombs = Bombs.Select(Function(bomb) New BombState With {
                .Id = bomb.Id,
                .Position = bomb.Position,
                .Radius = bomb.Radius,
                .Countdown = bomb.Countdown,
                .ExplosionRadius = bomb.ExplosionRadius
            }).ToList(),
            .HealthOrbs = HealthOrbs.Select(Function(orb) New HealthState With {
                .Id = orb.Id,
                .Position = orb.Position,
                .Radius = orb.Radius,
                .Amount = orb.Amount
            }).ToList(),
            .Projectiles = Projectiles.Select(Function(proj) New ProjectileState With {
                .Id = proj.Id,
                .Position = proj.Position,
                .Radius = proj.Radius,
                .Velocity = proj.RigidBody.Velocity
            }).ToList(),
            .Towers = Towers.Select(Function(tower) New TowerState With {
                .Id = tower.Id,
                .Position = tower.Position,
                .TowerType = GetTowerType(tower)
            }).ToList(),
            .Level = Level,
            .Currency = Currency,
            .EnemiesRemaining = EnemiesRemaining,
            .GameHealth = GameHealth,
            .MaxGameHealth = MaxGameHealth
        }
        connection.Send(state)
    End Sub

    Private Function GetTowerType(tower As Tower) As TowerType
        If TypeOf tower Is SpiralTower Then Return TowerType.Spiral
        If TypeOf tower Is BurstTower Then Return TowerType.Burst
        If TypeOf tower Is RapidTower Then Return TowerType.Rapid
        If TypeOf tower Is SniperTower Then Return TowerType.Sniper
        Return TowerType.Point
    End Function

    Private Sub ApplyMap(mapData As MapDataMessage)
        Level = mapData.Level
        SidePanel.Size = New Vector2(mapData.SidePanelWidth, sender.Window.ClientBounds.Height)
        PlayField.Position = New Vector2(mapData.SidePanelWidth, 0)
        PlayField.Size = mapData.PlayfieldSize
        PathPoints.Clear()
        PathPoints.AddRange(mapData.Path)
        For Each node As CircleElement In PathNodes
            RemoveElement(node)
        Next
        PathNodes.Clear()
        For Each segment As RectangleElement In PathSegments
            RemoveElement(segment)
        Next
        PathSegments.Clear()
        For Each point As Vector2 In PathPoints
            Dim marker As New CircleElement(Me) With {
                .Size = New Vector2(10.0F),
                .FillColor = Color.DimGray
            }
            marker.Position = point - New Vector2(5.0F)
            PathNodes.Add(marker)
            AddElement(marker)
        Next
        BuildPathSegments()
    End Sub

    Private Sub ApplyGameState(state As GameStateMessage)
        Level = state.Level
        Currency = state.Currency
        EnemiesRemaining = state.EnemiesRemaining
        GameHealth = state.GameHealth
        MaxGameHealth = state.MaxGameHealth

        SyncEnemies(state.Enemies)
        SyncBombs(state.Bombs)
        SyncHealthOrbs(state.HealthOrbs)
        SyncProjectiles(state.Projectiles)
        SyncTowers(state.Towers)
        If GameRunning AndAlso GameHealth <= 0 Then
            StopGame(False)
        End If
    End Sub

    Private Sub SyncEnemies(states As List(Of EnemyState))
        Dim activeIds As New HashSet(Of Guid)(states.Select(Function(s) s.Id))
        For Each enemy As Enemy In Enemies.ToList()
            If Not activeIds.Contains(enemy.Id) Then
                RemoveEnemy(enemy)
            End If
        Next

        For Each state As EnemyState In states
            Dim enemy As Enemy = Nothing
            If Not EnemyLookup.TryGetValue(state.Id, enemy) Then
                enemy = New Enemy(Me, state.Position, state.Radius, 0.0F, state.MaxHealth, state.TypeBlend)
                enemy.Id = state.Id
                Enemies.Add(enemy)
                EnemyLookup(enemy.Id) = enemy
                AddElement(enemy.Visual)
            End If
            enemy.Position = state.Position
            enemy.Health = state.Health
            enemy.MaxHealth = state.MaxHealth
            enemy.TypeBlend = state.TypeBlend
            enemy.UpdateVisual()
        Next
    End Sub

    Private Sub SyncBombs(states As List(Of BombState))
        Dim activeIds As New HashSet(Of Guid)(states.Select(Function(s) s.Id))
        For Each bomb As Bomb In Bombs.ToList()
            If Not activeIds.Contains(bomb.Id) Then
                RemoveBomb(bomb)
            End If
        Next

        For Each state As BombState In states
            Dim bomb As Bomb = Nothing
            If Not BombLookup.TryGetValue(state.Id, bomb) Then
                bomb = New Bomb(Me, state.Position, state.Radius, state.Countdown, state.ExplosionRadius)
                bomb.Id = state.Id
                Bombs.Add(bomb)
                BombLookup(bomb.Id) = bomb
                AddElement(bomb.Visual)
                AddElement(bomb.TimerText)
            End If
            bomb.Position = state.Position
            bomb.Countdown = state.Countdown
            bomb.ExplosionRadius = state.ExplosionRadius
            bomb.UpdateVisual()
        Next
    End Sub

    Private Sub SyncHealthOrbs(states As List(Of HealthState))
        Dim activeIds As New HashSet(Of Guid)(states.Select(Function(s) s.Id))
        For Each orb As HealthOrb In HealthOrbs.ToList()
            If Not activeIds.Contains(orb.Id) Then
                RemoveHealthOrb(orb)
            End If
        Next

        For Each state As HealthState In states
            Dim orb As HealthOrb = Nothing
            If Not HealthLookup.TryGetValue(state.Id, orb) Then
                orb = New HealthOrb(Me, state.Position, state.Radius, state.Amount)
                orb.Id = state.Id
                HealthOrbs.Add(orb)
                HealthLookup(orb.Id) = orb
                AddElement(orb.Visual)
            End If
            orb.Position = state.Position
            orb.Amount = state.Amount
            orb.UpdateVisual()
        Next
    End Sub

    Private Sub SyncProjectiles(states As List(Of ProjectileState))
        Dim activeIds As New HashSet(Of Guid)(states.Select(Function(s) s.Id))
        For Each projectile As Projectile In Projectiles.ToList()
            If Not activeIds.Contains(projectile.Id) Then
                RemoveProjectile(projectile)
            End If
        Next

        For Each state As ProjectileState In states
            Dim projectile As Projectile = Nothing
            If Not ProjectileLookup.TryGetValue(state.Id, projectile) Then
                projectile = New Projectile(Me, state.Position, state.Radius, state.Velocity, 0.0F, 1.0F)
                projectile.Id = state.Id
                Projectiles.Add(projectile)
                ProjectileLookup(projectile.Id) = projectile
                AddElement(projectile.Visual)
            End If
            projectile.Position = state.Position
            projectile.RigidBody.Velocity = state.Velocity
            projectile.UpdateVisual()
        Next
    End Sub

    Private Sub SyncTowers(states As List(Of TowerState))
        Dim activeIds As New HashSet(Of Guid)(states.Select(Function(s) s.Id))
        For Each tower As Tower In Towers.ToList()
            If Not activeIds.Contains(tower.Id) Then
                Towers.Remove(tower)
                TowerLookup.Remove(tower.Id)
                RemoveElement(tower.Visual)
            End If
        Next

        For Each state As TowerState In states
            Dim tower As Tower = Nothing
            If Not TowerLookup.TryGetValue(state.Id, tower) Then
                tower = CreateTower(state.TowerType, state.Position)
                tower.Id = state.Id
                Towers.Add(tower)
                TowerLookup(tower.Id) = tower
                AddElement(tower.Visual)
                SpawnTowerPlacementEffect(state.Position) ' Ripple effect for network-synced towers
            End If
            tower.Position = state.Position
            tower.UpdateVisual()
        Next
    End Sub

